# ViewStats Monitor — environment variables
# Copy to .env and fill in required values

# Required: ViewStats Bearer token
VS_TOKEN=

# Required: Feishu bot webhook URL
FEISHU_BOT_URL=

# ViewStats query parameters
CATEGORY_ID=0
COUNTRY=all
INTERVAL=weekly

# Long/short video split threshold (seconds)
DURATION_THRESHOLD_SECS=300

# Translation backend: "gemini" or "google"
TRANSLATE_BACKEND=gemini

# Required if TRANSLATE_BACKEND=gemini
GEMINI_API_KEY=

# Number of top videos to translate per category
TRANSLATE_TOP_N=5
